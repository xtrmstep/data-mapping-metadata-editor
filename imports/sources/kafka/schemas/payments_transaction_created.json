{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "event_id": {"type": "string"},
    "transaction": {
      "type": "object",
      "properties": {
        "transaction_id": {"type": "string"},
        "player_id": {"type": "integer"},
        "amount": {"type": "number"},
        "currency": {"type": "string"},
        "payment_method": {
          "type": "object",
          "properties": {
            "type": {"type": "string"},
            "provider": {"type": "string"}
          }
        }
      }
    },
    "risk_flags": {
      "type": "array",
      "items": {"type": "string"}
    },
    "created_at": {"type": "string"}
  }
}
