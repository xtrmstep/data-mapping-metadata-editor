{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "alert_id": {"type": "integer"},
    "severity": {"type": "string"},
    "rule": {
      "type": "object",
      "properties": {
        "name": {"type": "string"},
        "version": {"type": "string"}
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "entity_type": {"type": "string"},
          "entity_id": {"type": "string"}
        }
      }
    },
    "triggered_at": {"type": "string"}
  }
}
