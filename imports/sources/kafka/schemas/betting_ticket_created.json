{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "event_id": {"type": "string"},
    "ticket": {
      "type": "object",
      "properties": {
        "ticket_id": {"type": "integer"},
        "player_id": {"type": "integer"},
        "stake": {"type": "number"},
        "currency": {"type": "string"}
      },
      "required": ["ticket_id", "player_id"]
    },
    "selections": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "market_id": {"type": "integer"},
          "selection_id": {"type": "integer"},
          "odds": {"type": "number"}
        }
      }
    },
    "created_at": {"type": "string"}
  },
  "required": ["event_id", "ticket", "created_at"]
}
